#!/usr/bin/env bash
# devbox-global-update-flake
# Lists devbox global packages, identifies flake packages,
# checks latest GitHub version, and optionally updates them.
set -euo pipefail

# ── Argument parsing ──
SHOW_HELP=false
UPDATE_MODE=false
declare -a UPDATE_TARGETS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--update)
            UPDATE_MODE=true
            shift
            # Check if next arg is a package name (not a flag)
            while [[ $# -gt 0 && ! "$1" == -* ]]; do
                UPDATE_TARGETS+=("$1")
                shift
            done
            ;;
        -h|--help)
            SHOW_HELP=true
            shift
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

if $SHOW_HELP; then
    echo "Usage: $(basename "$0") [OPTIONS]"
    echo "Check and optionally update devbox global flake packages."
    echo ""
    echo "  (no args)    Show version comparison table"
    echo "  -u, --update Interactive: select packages to update"
    echo "  -u PKG [...] Update specific packages (e.g. opencode rtk)"
    echo "  -h, --help   Show this help"
    exit 0
fi

DEVBOX_GLOBAL_PATH="$(devbox global path)"
DEVBOX_JSON="$DEVBOX_GLOBAL_PATH/devbox.json"
DEVBOX_D="$DEVBOX_GLOBAL_PATH/devbox.d"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Parse installed versions from `devbox global list` ──
declare -A INSTALLED
while IFS= read -r line; do
    line="${line#\* }"
    if [[ "$line" == path:* ]]; then
        name="${line#path:}"
        name="${name#devbox.d/}"
        INSTALLED["$name"]="flake"
    else
        pkg="${line%% -*}"
        ver="${line##* - }"
        ver="${ver## }"
        name="${pkg%@*}"
        INSTALLED["$name"]="$ver"
    fi
done < <(devbox global list 2>/dev/null)

# ── Extract flake package names from devbox.json (JSONC-safe) ──
declare -a FLAKES=()
while IFS= read -r entry; do
    if [[ "$entry" == path:* ]]; then
        name="${entry#path:}"
        name="${name#devbox.d/}"
        FLAKES+=("$name")
    fi
done < <(grep -oP '"path:devbox\.d/[^"]+"|"[^"]+@latest"' "$DEVBOX_JSON" | tr -d '"' | grep '^path:')

# ── For each flake, extract GitHub source + version from flake.nix ──
declare -A FLAKE_OWNER FLAKE_REPO FLAKE_VERSION FLAKE_TYPE

for name in "${FLAKES[@]}"; do
    flake_nix="$DEVBOX_D/$name/flake.nix"
    [[ -f "$flake_nix" ]] || continue

    # Extract version from explicit version attribute
    ver="$(grep -oP '\bversion\s*=\s*"\K[^"]+' "$flake_nix" | head -1 || true)"

    # Fallback: extract version from flake input URL refs (e.g. github:owner/repo/v1.2.3)
    if [[ -z "$ver" ]]; then
        ver="$(grep -oP '"github:[^/"]+/[^/"]+/\K[^"]+' "$flake_nix" | grep -vE '^(nixos-unstable|main|master|develop|nightly)$' | head -1 || true)"
        ver="${ver#v}"
    fi

    FLAKE_VERSION["$name"]="$ver"

    found_source=false

    # Strategy 1: fetchFromGitHub with owner/repo attrs (most specific, no false positives)
    owner="$(grep -oP 'owner\s*=\s*"\K[^"]+' "$flake_nix" | grep -v NixOS | head -1 || true)"
    repo="$(grep -oP 'repo\s*=\s*"\K[^"]+' "$flake_nix" | grep -v nixpkgs | head -1 || true)"
    if [[ -n "$owner" && -n "$repo" ]]; then
        FLAKE_OWNER["$name"]="$owner"
        FLAKE_REPO["$name"]="$repo"
        FLAKE_TYPE["$name"]="fetchFromGitHub"
        found_source=true
    fi

    # Strategy 2: github:owner/repo input URLs (non-nixpkgs)
    if ! $found_source; then
        input_url="$(grep -oP '"github:[^"]+' "$flake_nix" | grep -v 'github:NixOS/nixpkgs' | head -1 || true)"
        if [[ -n "$input_url" ]]; then
            input_url="${input_url#\"}"
            input_url="${input_url#github:}"
            owner="${input_url%%/*}"
            rest="${input_url#*/}"
            repo="${rest%%/*}"
            FLAKE_OWNER["$name"]="$owner"
            FLAKE_REPO["$name"]="$repo"
            FLAKE_TYPE["$name"]="github-input"
            found_source=true
        fi
    fi

    # Strategy 3: fetchurl/fetchzip with github.com/owner/repo URL (least specific, most false positives)
    if ! $found_source; then
        url="$(grep -oP 'github\.com/[^/"]+/[^/"]+' "$flake_nix" | grep -v 'NixOS/nixpkgs' | head -1 || true)"
        if [[ -n "$url" ]]; then
            owner="$(echo "$url" | cut -d'/' -f2)"
            repo="$(echo "$url" | cut -d'/' -f3)"
            repo="${repo%.git}"
            FLAKE_OWNER["$name"]="$owner"
            FLAKE_REPO["$name"]="$repo"
            FLAKE_TYPE["$name"]="fetchurl"
            found_source=true
        fi
    fi
done

# ── Check latest GitHub version ──
declare -A LATEST

for name in "${FLAKES[@]}"; do
    owner="${FLAKE_OWNER[$name]:-}"
    repo="${FLAKE_REPO[$name]:-}"

    if [[ -z "$owner" || -z "$repo" ]]; then
        LATEST["$name"]="unknown"
        continue
    fi

    # Try GitHub releases first (exclude pre-releases)
    latest_tag="$(gh release list -R "$owner/$repo" --limit 10 -L 10 --json tagName,isPrerelease -q '.[] | select(.isPrerelease == false) | .tagName' 2>/dev/null | head -1 || true)"

    if [[ -n "$latest_tag" ]]; then
        # Strip common prefixes: v, bun-v, dev-
        latest_ver="${latest_tag#v}"
        latest_ver="${latest_ver#bun-v}"
        LATEST["$name"]="$latest_ver"
    else
        # Fall back to tags
        latest_tag="$(gh api "repos/$owner/$repo/tags" --jq '.[0].name' 2>/dev/null || true)"
        if [[ -n "$latest_tag" ]]; then
            latest_ver="${latest_tag#v}"
            LATEST["$name"]="$latest_ver"
        else
            # Fall back to default branch
            latest_branch="$(gh api "repos/$owner/$repo" --jq '.default_branch' 2>/dev/null || true)"
            if [[ -n "$latest_branch" ]]; then
                LATEST["$name"]="branch:$latest_branch"
            else
                LATEST["$name"]="unknown"
            fi
        fi
    fi
done

# ── Update a single flake package ──
update_flake() {
    local name="$1" old_ver="$2" new_ver="$3"
    local flake_nix="$DEVBOX_D/$name/flake.nix"
    local owner="${FLAKE_OWNER[$name]:-}"
    local repo="${FLAKE_REPO[$name]:-}"

    [[ -f "$flake_nix" ]] || { echo "  File not found"; return 1; }
    [[ -z "$old_ver" || "$old_ver" == "flake" ]] && { echo "  Cannot determine installed version"; return 1; }
    [[ "$old_ver" == "$new_ver" ]] && { echo "  Already at latest: $old_ver"; return 0; }

    echo "  ${BOLD}${name}${NC}: $old_ver → $new_ver  (${owner}/${repo})"

    # Escape dots for sed
    old_ver_escaped="${old_ver//\./\\.}"

    # 1. Update version field
    if grep -qP "\\bversion\\s*=\\s*\"$old_ver_escaped\"" "$flake_nix"; then
        sed -ri "s/(\\bversion\\s*=\\s*)\"$old_ver_escaped\"/\\1\"$new_ver\"/" "$flake_nix"
        echo "    ✓ version field updated"
    else
        echo "    ! Could not find version = \"$old_ver\" in flake.nix — skipping"
        return 1
    fi

    # 2. Update input URL refs for github-input type flakes (e.g. github:owner/repo/v1.2.3)
    if [[ "${FLAKE_TYPE[$name]:-}" == "github-input" ]]; then
        sed -ri "s|(/v)$old_ver_escaped\"|\1$new_ver\"|g; s|(/)${old_ver_escaped}\"|\1${new_ver}\"|g" "$flake_nix"
        echo "    ✓ input URL ref updated"
    fi

    # 3. Reset all sha256 hashes to pkgs.lib.fakeHash (preserve old hash in comment)
    if grep -q '"sha256-' "$flake_nix" 2>/dev/null; then
        sed -ri 's/"(sha256-[^"]+)"/pkgs.lib.fakeHash;  # FIXME: was "\1"/' "$flake_nix"
        echo "    ✓ hashes reset to pkgs.lib.fakeHash"
    else
        echo "    - no hashes to reset"
    fi
}

# ── Print results ──
printf "\n${BOLD}${CYAN}═══ Devbox Global Flake Packages ═══${NC}\n\n"
printf "${BOLD}%-15s %-25s %-15s %-15s %-8s${NC}\n" "PACKAGE" "SOURCE" "INSTALLED" "LATEST" "STATUS"
printf "%-15s %-25s %-15s %-15s %-8s\n" "───────" "──────" "─────────" "──────" "──────"

for name in "${FLAKES[@]}"; do
    installed="${FLAKE_VERSION[$name]:-${INSTALLED[$name]:-unknown}}"
    latest="${LATEST[$name]:-unknown}"
    type="${FLAKE_TYPE[$name]:-unknown}"
    owner="${FLAKE_OWNER[$name]:-}"
    repo="${FLAKE_REPO[$name]:-}"

    source_display="$owner/$repo"
    [[ -z "$owner" ]] && source_display="$type"

    # Determine status
    if [[ "$latest" == "unknown" || "$installed" == "unknown" || "$latest" == branch:* ]]; then
        status="${YELLOW}??${NC}"
    elif [[ "$installed" == "$latest" ]]; then
        status="${GREEN}✓${NC}"
    else
        status="${RED}↑${NC}"
    fi

    latest_display="${latest#branch:}"

    printf "%-15s %-25s %-15s %-15s %b\n" "$name" "$source_display" "$installed" "$latest_display" "$status"
done

printf "\n${BOLD}${CYAN}═══ Nixpkgs Packages ═══${NC}\n\n"
printf "${BOLD}%-20s %-15s %-8s${NC}\n" "PACKAGE" "INSTALLED" "SOURCE"
printf "%-20s %-15s %-8s\n" "───────" "─────────" "──────"

for name in "${!INSTALLED[@]}"; do
    ver="${INSTALLED[$name]}"
    [[ "$ver" == "flake" ]] && continue
    is_flake=false
    for fname in "${FLAKES[@]}"; do
        [[ "$name" == "$fname" ]] && { is_flake=true; break; }
    done
    $is_flake && continue
    printf "%-20s %-15s %s\n" "$name" "$ver" "nixpkgs"
done | sort

printf "\n"
printf "${GREEN}✓${NC} = up to date  ${RED}↑${NC} = update available  ${YELLOW}??${NC} = unknown\n"

# ── Update workflow ──
if $UPDATE_MODE; then
    # Build list of upgradable packages
    declare -a UPGRADABLE=()
    for name in "${FLAKES[@]}"; do
        installed="${FLAKE_VERSION[$name]:-${INSTALLED[$name]:-unknown}}"
        latest="${LATEST[$name]:-unknown}"
        if [[ "$installed" != "unknown" && "$latest" != "unknown" && "$latest" != branch:* && "$installed" != "$latest" ]]; then
            UPGRADABLE+=("$name")
        fi
    done

    # Determine targets
    declare -a TARGETS=()

    if [[ ${#UPDATE_TARGETS[@]} -gt 0 ]]; then
        # Non-interactive: validate specified targets against upgradable
        for target in "${UPDATE_TARGETS[@]}"; do
            found=false
            for name in "${UPGRADABLE[@]}"; do
                [[ "$name" == "$target" ]] && { found=true; break; }
            done
            if $found; then
                TARGETS+=("$target")
            else
                # Maybe user specified a package that is up to date
                is_flake=false
                for name in "${FLAKES[@]}"; do
                    [[ "$name" == "$target" ]] && { is_flake=true; break; }
                done
                if $is_flake; then
                    installed="${FLAKE_VERSION[$target]:-${INSTALLED[$target]:-unknown}}"
                    echo "  Package '$target' is already at $installed (no update needed)."
                else
                    echo "  Package '$target' is not a known flake package."
                fi
            fi
        done
    else
        # Interactive selection
        if [[ ${#UPGRADABLE[@]} -eq 0 ]]; then
            echo "${GREEN}All packages are up to date.${NC}"
            exit 0
        fi

        echo ""
        echo "${BOLD}${CYAN}Packages with updates available:${NC}"
        i=1
        for name in "${UPGRADABLE[@]}"; do
            installed="${FLAKE_VERSION[$name]:-${INSTALLED[$name]:-unknown}}"
            echo "  $i) $name  $installed → ${LATEST[$name]}"
            ((i++))
        done
        echo ""
        echo "Select packages to update:"
        echo "  - Comma-separated numbers (e.g. 1,3,5)"
        echo "  - 'a' for all"
        echo "  - Enter to skip"
        echo ""
        printf "> "
        read -r selection

        case "$selection" in
            a|A) TARGETS=("${UPGRADABLE[@]}") ;;
            "")
                echo "No updates applied."
                exit 0
                ;;
            *)
                IFS=',' read -ra nums <<< "$selection"
                for num in "${nums[@]}"; do
                    num="${num// }"
                    if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#UPGRADABLE[@]} )); then
                        TARGETS+=("${UPGRADABLE[$((num-1))]}")
                    fi
                done
                ;;
        esac

        if [[ ${#TARGETS[@]} -eq 0 ]]; then
            echo "No valid selections."
            exit 0
        fi
    fi

    # Apply updates
    echo ""
    echo "${BOLD}${CYAN}Applying updates...${NC}"
    for name in "${TARGETS[@]}"; do
        echo ""
        installed="${FLAKE_VERSION[$name]:-${INSTALLED[$name]:-unknown}}"
        latest="${LATEST[$name]:-unknown}"
        update_flake "$name" "$installed" "$latest"
    done
    echo ""
    echo "${BOLD}${GREEN}All updates applied.${NC}"
    echo ""
    echo "Next steps:"
    echo "  1. Run ${BOLD}devbox global update${NC} to build (will fail on hash mismatches)"
    echo "  2. Paste the suggested hashes into the upgraded flake.nix files"
    echo "  3. Repeat until build succeeds"
    echo "  4. Sync: ${BOLD}cp devbox.json devbox.d/ \$(devbox global path)/${NC}"
fi

printf "\n"