{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "fzf@latest",
    "starship@latest",
    "ripgrep@latest",
    "gh@latest",
    "zoxide@latest",
    "tmux@latest",
    "go@latest",
    "cargo@latest",
    "wl-clipboard@latest",
    "statix@latest",
    "git-credential-oauth@latest",
    "git-credential-manager@latest",
    "gitFull@latest",
    "delta@latest",
    "luarocks@latest",
    "ghq@latest",
    "tree@latest",
    "difftastic@latest",
    "doggo@latest",
    "tig@latest",
    "tree-sitter@latest",
    "chezmoi@latest",
    "bitwarden-cli@latest",
    "atuin@latest",
    "nerd-fonts.hack@latest",
    "nerd-fonts.noto@latest",
    "nerd-fonts.fira-code@latest",
    "fd@latest",
    "libuuid@latest",
    "dconf@latest",
    "jq@latest",
    "libsecret@latest",
    "zenity@latest",
    "podman@latest",
    "python312@latest",
    "jdk21@latest",
    "unzip@latest",
    "p7zip@latest",
    "evtest@latest",
    "gcc@latest",
    "dos2unix@latest",
    "htop@latest",
    "glibcLocales@latest",
    "sesh@latest",
    "perl5Packages.PerlTidy@latest",
    "nix-search-cli@latest",
    "nix-prefetch-git@latest",
    "uv@latest",
    "xxd@latest",
    "nodejs@latest",
    "file@latest",
    "path:devbox.d/neovim",
    "path:devbox.d/tree-sitter-perl",
    "path:devbox.d/blesh",
    "path:devbox.d/openspec",
    "path:devbox.d/bun",
    "path:devbox.d/open-code-review",
    "path:devbox.d/opencode",
    "path:devbox.d/opencommit",
    "path:devbox.d/graphify",
    "path:devbox.d/skills",
    "path:devbox.d/rtk",
    "path:devbox.d/agent-browser",
    "path:devbox.d/playwright-cli",
    "path:devbox.d/codeburn",
    "path:devbox.d/codecanary",
    "path:devbox.d/codegraph",
    "path:devbox.d/whichllm",
    "path:devbox.d/agentmemory",
    "path:devbox.d/aicommits",
    "path:devbox.d/beads",
    "path:devbox.d/impeccable",
    "path:devbox.d/skillspector",
    "path:devbox.d/strix",
    "path:devbox.d/herdr",
    "path:devbox.d/hunk",
    "path:devbox.d/omniroute",
    "path:devbox.d/dcg",
    "path:devbox.d/firecrawl",
    "path:devbox.d/wigolo",
    "path:devbox.d/jcode",
  ],
  "env": {
    "EDITOR":         "vi",
    "VISUAL":         "vi",
    "NIX_CONFIG":     "experimental-features = nix-command flakes",
    "LOCALE_ARCHIVE": "${DEVBOX_PACKAGES_DIR}/lib/locale/locale-archive",
    "VENV_DIR":       "$HOME/.local/share/devbox/global/python-venv",
    "PYTHONPATH":     "${DEVBOX_PACKAGES_DIR}/lib/python3.12/site-packages${PYTHONPATH:+:$PYTHONPATH}",
    "OPENCODE_EXPERIMENTAL_BACKGROUND_SUBAGENTS": "1",
  },
  "shell": {
    "init_hook": [
      "source \"$(devbox global path)/bin/init-hook\"",
    ],
    "scripts": {
      "update-flake": "\"$(devbox global path)/bin/update-flake\" \"$@\"",
      "config-edit": [
        "$EDITOR $(devbox global path)/devbox.json",
      ],
      "config-pull": [
        "devbox global pull https://github.com/rbelem/devbox-global.git",
      ],
      "config-push": [
        "devbox global push https://github.com/rbelem/devbox-global.git",
      ],
      "config-sync": "\"$(devbox global path)/bin/config-sync\" \"$@\"",
      "upload-flakes": "\"$(devbox global path)/bin/upload-flakes\" \"$@\"",
      "secrets-setup": "\"$(devbox global path)/bin/secrets-setup\" \"$@\"",
      "secrets-refresh": "\"$(devbox global path)/bin/secrets-refresh\" \"$@\"",
      "secrets-add": "\"$(devbox global path)/bin/secrets-add\" \"$@\"",
      "first-install": [
        "devbox global run setup-git",
        "devbox global run setup-tmux",
        "devbox global run setup-nerd-fonts",
        "devbox global run setup-themes",
        "devbox global run setup-neovim",
      ],
      "python-install": [
        "[ -d \"$VENV_DIR\" ] || python3 -m venv \"$VENV_DIR\"",
        ". \"$VENV_DIR/bin/activate\" && pip install \"${@}\"",
      ],
      "python-update": [
        ". \"$VENV_DIR/bin/activate\" && pip install --upgrade pip",
        ". \"$VENV_DIR/bin/activate\" && pip list --outdated --format=freeze | cut -d= -f1 | xargs -r pip install --upgrade",
      ],
      "setup-nerd-fonts": "\"$(devbox global path)/bin/setup-nerd-fonts\" \"$@\"",
      "setup-neovim": [
        "git clone https://github.com/rbelem/nvchad-custom $HOME/.config/nvim",
      ],
      "setup-devbox": "\"$(devbox global path)/bin/setup-devbox\" \"$@\"",
      "setup-devbox-bashrc": "\"$(devbox global path)/bin/setup-devbox-bashrc\" \"$@\"",
      "setup-flatpak": "\"$(devbox global path)/bin/setup-flatpak\" \"$@\"",
      "fix-flatpak-fonts": "\"$(devbox global path)/bin/fix-flatpak-fonts\" \"$@\"",
      "fix-protonvpn-fonts": "\"$(devbox global path)/bin/fix-protonvpn-fonts\" \"$@\"",
      "setup-git": "\"$(devbox global path)/bin/setup-git\" \"$@\"",
      "setup-podman": "\"$(devbox global path)/bin/setup-podman\" \"$@\"",
      "setup-themes": "\"$(devbox global path)/bin/setup-themes\" \"$@\"",
      "setup-tmux": "\"$(devbox global path)/bin/setup-tmux\" \"$@\"",
      "setup-kde-secrets-service": "\"$(devbox global path)/bin/setup-kde-secrets-service\" \"$@\"",
      "nix-store-gc": "nix store gc",
    },
  },
}
