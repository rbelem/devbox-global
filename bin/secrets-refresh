#!/usr/bin/env bash
# secrets-refresh
# Fetch secrets from Bitwarden → $XDG_RUNTIME_DIR/devbox-secrets.sh (600).
# Auto-unlocks via system keyring. Run: devbox global run secrets-refresh
set -euo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; NC=$'\033[0m'

# ── bw wrapper: always pass --session if available (env var unreliable) ──
bw_sesh() {
  if [ -n "${BW_SESSION:-}" ]; then
    command bw --session "$BW_SESSION" "$@"
  else
    command bw "$@"
  fi
}

XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}"
if [ -z "$XDG_RUNTIME_DIR" ]; then
  echo "${RED}ERROR:${NC} \$XDG_RUNTIME_DIR is not set. Cannot write cache." >&2
  exit 1
fi

CACHE="$XDG_RUNTIME_DIR/devbox-secrets.sh"

# ── Resolve BW_SESSION from keyring (no prompt) ──
if command -v secret-tool >/dev/null 2>&1; then
  master_pw="$(secret-tool lookup bitwarden master-password 2>/dev/null)" || {
    echo "${YELLOW}Bitwarden master password not found in keyring.${NC}" >&2
    echo "  Run once: devbox global run secrets-setup" >&2
    exit 1
  }
  export BW_SESSION="$(bw unlock --raw "$master_pw" 2>/dev/null)" || {
    echo "${RED}Failed to unlock Bitwarden. Wrong master password in keyring?${NC}" >&2
    echo "  Run: devbox global run secrets-setup  (re-prompts for password)" >&2
    exit 1
  }
  unset master_pw
else
  echo "${YELLOW}secret-tool not found. Did 'devbox global install' succeed?${NC}" >&2
  exit 1
fi

# Validate session
bw_sesh get item devbox-global/github-token >/dev/null 2>&1 || {
  echo "${RED}Cannot reach Bitwarden vault. Check your login status.${NC}" >&2
  exit 1
}

# name → env var
declare -A ITEMS=(
  ["devbox-global/github-token"]="GITHUB_TOKEN"
  ["devbox-global/brave-api-key"]="BRAVE_API_KEY"
  ["devbox-global/mistral-api-key"]="MISTRAL_API_KEY"
  ["devbox-global/firecrawl-api-key"]="FIRECRAWL_API_KEY"
  ["devbox-global/openai-api-key"]="OPENAI_API_KEY"
  ["devbox-global/opencode-auth-cookie"]="OPENCODE_GO_AUTH_COOKIE"
  ["devbox-global/opencode-workspace-id"]="OPENCODE_GO_WORKSPACE_ID"
)

declare -A CUSTOM_FIELDS=(
  ["devbox-global/openai-api-key"]="OPENAI_BASE_URL,OPENAI_MODEL"
)

# ── Fetch all secrets → cache file ──
errors=0
tmp="$(mktemp)"
{
  echo "# Auto-generated by secrets-refresh. Do not edit."
  echo "# Regenerate: devbox global run secrets-refresh"
  echo "# Source: Bitwarden vault ($(date -u +%Y-%m-%dT%H:%M:%SZ))"
  echo ""
  for name in "${!ITEMS[@]}"; do
    var="${ITEMS[$name]}"
    item_json="$(bw_sesh get item "$name" 2>/dev/null)" || {
      printf '# %s: bw get item failed\n' "$var" >&2
      ((errors++)) || true
      continue
    }
    val="$(echo "$item_json" | jq -r '.login.password // empty')"
    if [ -n "$val" ]; then
      printf 'export %s=%q\n' "$var" "$val"
    else
      printf '# %s: not found or empty in vault\n' "$var" >&2
    fi
    if [ "${CUSTOM_FIELDS[$name]:-}" ]; then
      IFS=',' read -ra field_names <<< "${CUSTOM_FIELDS[$name]}"
      for field_name in "${field_names[@]}"; do
        field_val="$(echo "$item_json" | jq -r --arg fname "$field_name" \
          '.fields[] | select(.name == $fname) | .value // empty')"
        if [ -n "$field_val" ]; then
          printf 'export %s=%q\n' "$field_name" "$field_val"
        fi
      done
    fi
  done
  echo ""
  echo 'export GH_TOKEN=$GITHUB_TOKEN'
  echo 'export WIGOLO_GITHUB_TOKEN=$GITHUB_TOKEN'
} > "$tmp"

if [ "$errors" -gt 0 ]; then
  echo "${YELLOW}⚠ $errors item(s) failed. Cache may be incomplete.${NC}" >&2
fi

chmod 600 "$tmp"
mv "$tmp" "$CACHE"
echo "${GREEN}✓ Secrets cached to $CACHE${NC}"
