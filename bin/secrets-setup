#!/usr/bin/env bash
# secrets-setup
# One-time migration: plaintext ~/.bashrc.d/ secrets → Bitwarden vault (Login items).
# Stores master password in system keyring for auto-unlock.
set -euo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; NC=$'\033[0m'

# ── Password prompt: try GUI dialogs, fall back to terminal ──
prompt_password() {
  local prompt="$1"
  # Prefer zenity (GTK dialog, works on KDE too)
  if command -v zenity >/dev/null 2>&1; then
    zenity --password --title="$prompt" 2>/dev/null
  elif command -v kdialog >/dev/null 2>&1; then
    kdialog --password "$prompt" 2>/dev/null
  elif [ -n "${SSH_ASKPASS:-}" ] && command -v "$SSH_ASKPASS" >/dev/null 2>&1; then
    DISPLAY="${DISPLAY:-:0}" "$SSH_ASKPASS" "$prompt" 2>/dev/null
  else
    # Fallback: terminal prompt via /dev/tty
    echo -n "$prompt: " > /dev/tty
    read -rs password < /dev/tty
    echo "" > /dev/tty
    echo "$password"
  fi
}

# ── Ensure logged in ──
if ! bw login --check >/dev/null 2>&1; then
  echo "${YELLOW}Not logged in to Bitwarden. Run: bw login${NC}" >&2
  exit 1
fi

# ── bw wrapper: always pass --session if available (env var unreliable after lock) ──
bw_sesh() {
  if [ -n "${BW_SESSION:-}" ]; then
    command bw --session "$BW_SESSION" "$@"
  else
    command bw "$@"
  fi
}

# ── Validate stored master password ──
# We validate by trying bw unlock --raw. If it returns a session key, password is good.
# After unlock, all subsequent bw commands MUST use --session because bw's daemon
# may still show as locked (bw ignores BW_SESSION env for auth state checks).
validate_session() {
  local pw="$1"
  local session
  session="$(bw unlock --raw "$pw" 2>/dev/null)" || return 1
  [ -n "$session" ] || return 1
  echo "$session"
}

master_pw=""
if command -v secret-tool >/dev/null 2>&1; then
  stored_pw="$(secret-tool lookup bitwarden master-password 2>/dev/null)" || true
  if [ -n "$stored_pw" ]; then
    session="$(validate_session "$stored_pw")" && {
      master_pw="$stored_pw"
      export BW_SESSION="$session"
    } || {
      echo "  ${YELLOW}⚠${NC} Stored keyring password doesn't work — re-prompting." >&2
      secret-tool clear bitwarden master-password 2>/dev/null || true
    }
  fi
fi

# ── Prompt user if no valid password yet ──
while [ -z "${master_pw:-}" ]; do
  echo "${YELLOW}Enter your Bitwarden master password (validated then stored in keyring).${NC}" >&2
  entered="$(prompt_password "Bitwarden master password")" || true

  if [ -z "$entered" ]; then
    echo "${RED}No password entered. Aborting.${NC}" >&2
    exit 1
  fi

  session="$(validate_session "$entered")" && {
    master_pw="$entered"
    export BW_SESSION="$session"
    echo "$master_pw" | secret-tool store --label="Bitwarden" bitwarden master-password 2>/dev/null && \
      echo "  ${GREEN}✓${NC} Master password stored in system keyring" >&2
  } || {
    echo "${RED}Wrong password. Try again.${NC}" >&2
  }
done


unset master_pw

# Validate session
bw_sesh get item devbox-global/github-token >/dev/null 2>&1 || true  # ignore — items may not exist yet

# name → env var
declare -A ITEMS=(
  ["devbox-global/github-token"]="GITHUB_TOKEN"
  ["devbox-global/mistral-api-key"]="MISTRAL_API_KEY"
  ["devbox-global/firecrawl-api-key"]="FIRECRAWL_API_KEY"
  ["devbox-global/openai-api-key"]="OPENAI_API_KEY"
  ["devbox-global/opencode-auth-cookie"]="OPENCODE_GO_AUTH_COOKIE"
  ["devbox-global/opencode-workspace-id"]="OPENCODE_GO_WORKSPACE_ID"
)

declare -A CUSTOM_FIELDS=(
  ["devbox-global/openai-api-key"]="OPENAI_BASE_URL,OPENAI_MODEL"
)

# ── Source existing plaintext files to extract values ──
BASHRC_D="$HOME/.bashrc.d"
for f in "$BASHRC_D"/10-github.sh "$BASHRC_D"/10-gemini.sh "$BASHRC_D"/10-mistral.sh \
         "$BASHRC_D"/10-firecrawl.sh "$BASHRC_D"/10-opencode.sh; do
  [ -f "$f" ] && . "$f"
done

mkfield() {
  local name="$1" value="$2"
  jq -n --arg name "$name" --arg value "$value" \
    '{type:0, name:$name, value:$value}'
}

# ── Create each vault item if missing ──
created=0; skipped=0; missing=0
for name in "${!ITEMS[@]}"; do
  var="${ITEMS[$name]}"
  val="${!var:-}"

  if bw_sesh get item "$name" >/dev/null 2>&1; then
    echo "  ${GREEN}✓${NC} $name (exists, skip)"
    ((skipped++)) || true; continue
  fi

  if [ -z "$val" ]; then
    echo "  DBG: empty val, skip" >&2
    echo "  ${YELLOW}⚠${NC} $name: \$$var not set (bashrc.d file missing or commented — skip)"
    ((missing++)) || true; continue
  fi

  item_json=$(jq -n \
    --arg name "$name" \
    --arg password "$val" \
    '{type: 1, login: {username: null, password: $password}, name: $name, fields: []}')

  if [ "${CUSTOM_FIELDS[$name]:-}" ]; then
    IFS=',' read -ra field_names <<< "${CUSTOM_FIELDS[$name]}"
    for field_name in "${field_names[@]}"; do
      field_val="${!field_name:-}"
      if [ -n "$field_val" ]; then
        field_json=$(mkfield "$field_name" "$field_val")
        item_json=$(echo "$item_json" | jq --argjson field "$field_json" '.fields += [$field]')
      fi
    done
  fi

  create_err="$(echo "$item_json" | bw_sesh encode 2>/dev/null | bw_sesh create item 2>&1)" || {
    echo "  ${RED}✗${NC} $name: $create_err" >&2
    echo "    value: ${val:0:30}... (${#val} chars)" >&2
    continue
  }
  echo "  ${GREEN}✓${NC} $name (created)"
  ((created++)) || true
done

# ── Verify retrieval ──
echo ""
echo "${BOLD}${CYAN}═══ Verification ═══${NC}"
for name in "${!ITEMS[@]}"; do
  if bw_sesh get item "$name" >/dev/null 2>&1; then
    echo "  ${GREEN}✓${NC} $name retrievable"
  else
    echo "  ${RED}✗${NC} $name NOT retrievable"
  fi
done

echo ""
echo "${BOLD}Summary:${NC} $created created, $skipped existed, $missing missing"
echo ""
echo "${YELLOW}Next steps:${NC}"
echo "  1. Run: devbox global run secrets-refresh   # populate cache"
echo "  2. Verify: cat \$XDG_RUNTIME_DIR/devbox-secrets.sh"
echo "  3. Start a new shell, check: env | grep GITHUB_TOKEN"
echo "  4. Once confirmed, delete plaintext files:"
echo "       rm ~/.bashrc.d/10-github.sh ~/.bashrc.d/10-gemini.sh \\"
echo "          ~/.bashrc.d/10-mistral.sh ~/.bashrc.d/10-firecrawl.sh \\"
echo "          ~/.bashrc.d/10-opencode.sh"
