#!/usr/bin/env bash
# secrets-add
# Create a Bitwarden Login item under the devbox-global/ namespace, the simple way.
#
# Usage:
#   secrets-add <vault-item-name> <env-var-name> [notes]
#
# Examples:
#   secrets-add devbox-global/brave-api-key BRAVE_API_KEY
#   secrets-add devbox-global/gemini-api-key GEMINI_API_KEY "free tier"
#
# Via devbox:
#   devbox global run secrets-add devbox-global/brave-api-key BRAVE_API_KEY
#   devbox global run -- secrets-add devbox-global/gemini-api-key GEMINI_API_KEY "free tier"
#
# Notes is optional (defaults to empty). Always runs secrets-refresh after
# successful creation so the new var lands in the cache immediately.
# Idempotent: refuses if the item already exists (use `bw edit` to rotate).
# Does NOT modify secrets-refresh — prints the exact ITEMS map line to add.
set -euo pipefail

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'; CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; NC=$'\033[0m'

# ── Args (positionals only — devbox run eats --flags) ──
if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "Usage: $0 <vault-item-name> <env-var-name> [notes]" >&2
  echo "" >&2
  echo "Examples:" >&2
  echo "  $0 devbox-global/brave-api-key BRAVE_API_KEY" >&2
  echo "  $0 devbox-global/gemini-api-key GEMINI_API_KEY \"free tier\"" >&2
  echo "" >&2
  echo "Via devbox (note the -- separator):" >&2
  echo "  devbox global run secrets-add devbox-global/brave-api-key BRAVE_API_KEY" >&2
  echo "  devbox global run -- secrets-add devbox-global/gemini-api-key GEMINI_API_KEY \"free tier\"" >&2
  exit 2
fi

ITEM_NAME="$1"
ENV_VAR="$2"
NOTES="${3:-}"

# ── Validate naming conventions (warn, don't block) ──
case "$ITEM_NAME" in
  devbox-global/*) ;;
  *) echo "${YELLOW}⚠${NC} '$ITEM_NAME' doesn't follow 'devbox-global/<slug>' convention (other scripts assume it)." >&2 ;;
esac
case "$ENV_VAR" in
  *[!A-Z0-9_]*)
    echo "${RED}\$ENV_VAR must be UPPER_SNAKE_CASE (got: $ENV_VAR)${NC}" >&2
    echo "" >&2
    echo "${YELLOW}Did you paste the secret value here?${NC}" >&2
    echo "  The secret is NOT passed as an argument — the script prompts for it (hidden)" >&2
    echo "  AFTER both identifiers are validated. Args are identifiers only:" >&2
    echo "    $0 <vault-item-name> <ENV_VAR_NAME> [notes]" >&2
    echo "  e.g.:" >&2
    echo "    $0 devbox-global/brave-api-key BRAVE_API_KEY" >&2
    exit 2
    ;;
esac

# ── Ensure bw installed + logged in ──
command -v bw >/dev/null 2>&1 || { echo "${RED}bw (Bitwarden CLI) not installed.${NC}" >&2; exit 1; }
bw login --check >/dev/null 2>&1 || { echo "${YELLOW}Not logged in to Bitwarden. Run: bw login${NC}" >&2; exit 1; }

bw_sesh() {
  if [ -n "${BW_SESSION:-}" ]; then command bw --session "$BW_SESSION" "$@"
  else command bw "$@"; fi
}

# ── Resolve BW_SESSION from keyring (no prompt) ──
if ! BW_SESSION="$(bw status 2>/dev/null | jq -r '.status // empty')" >/dev/null 2>&1; then
  BW_SESSION=""
fi
if [ "$(bw status 2>/dev/null | jq -r '.status')" = "locked" ]; then
  if command -v secret-tool >/dev/null 2>&1; then
    master_pw="$(secret-tool lookup bitwarden master-password 2>/dev/null)" || {
      echo "${YELLOW}Bitwarden master password not in keyring.${NC}" >&2
      echo "  Run once: devbox global run secrets-setup" >&2
      exit 1
    }
    BW_SESSION="$(bw unlock --raw "$master_pw" 2>/dev/null)" || {
      echo "${RED}Failed to unlock Bitwarden. Keyring password stale?${NC}" >&2
      echo "  Run: devbox global run secrets-setup" >&2; exit 1
    }
    export BW_SESSION
    unset master_pw
  else
    echo "${YELLOW}secret-tool not found. Run: devbox global run secrets-setup${NC}" >&2
    exit 1
  fi
fi

# ── Refuse if item already exists ──
if bw_sesh get item "$ITEM_NAME" >/dev/null 2>&1; then
  echo "${YELLOW}⚠${NC} '$ITEM_NAME' already exists. Use 'bw edit item <id>' to rotate." >&2
  exit 1
fi

# ── Prompt for secret value (hidden) ──
prompt_secret() {
  local prompt="$1"
  if command -v zenity >/dev/null 2>&1; then
    zenity --password --title="$prompt" 2>/dev/null
  elif command -v kdialog >/dev/null 2>&1; then
    kdialog --password "$prompt" 2>/dev/null
  else
    echo -n "$prompt: " > /dev/tty
    read -rs secret < /dev/tty
    echo "" > /dev/tty
    echo "$secret"
  fi
}

echo "${CYAN}Add Bitwarden Login item:${NC} $ITEM_NAME → \$$ENV_VAR" >&2
SECRET="$(prompt_secret "Secret value for $ITEM_NAME")" || true
[ -n "$SECRET" ] || { echo "${RED}Empty secret. Aborting.${NC}" >&2; exit 1; }

# ── Build Login item JSON ──
PAYLOAD="$(jq -n \
  --arg name "$ITEM_NAME" \
  --arg notes "$NOTES" \
  --arg password "$SECRET" \
  '{type:1, name:$name, notes:$notes, login:{username:"", password:$password}, fields:[]}')"

# ── Create ──
unset SECRET
ENC="$(printf '%s' "$PAYLOAD" | bw encode)"
ITEM_ID="$(echo "$ENC" | bw_sesh create item | jq -r '.id')"

if [ -z "$ITEM_ID" ] || [ "$ITEM_ID" = "null" ]; then
  echo "${RED}Failed to create item.${NC}" >&2
  exit 1
fi

echo "${GREEN}✓${NC} Created $ITEM_NAME (id: $ITEM_ID)" >&2

# ── Tell user what to add to secrets-refresh ──
SECRETS_REFRESH="$(dirname "$0")/secrets-refresh"
echo "" >&2
echo "${BOLD}Next step:${NC} register it in $SECRETS_REFRESH" >&2
echo "  Add this line to the ITEMS map:" >&2
echo "    ${CYAN}[\"$ITEM_NAME\"]=\"$ENV_VAR\"${NC}" >&2

# ── Always refresh cache after successful creation ──
echo "" >&2
echo "${CYAN}Running secrets-refresh...${NC}" >&2
SECRETS_REFRESH_BIN="$(dirname "$0")/secrets-refresh"
if [ -x "$SECRETS_REFRESH_BIN" ]; then
  # Call sibling script directly — avoids devbox wrapper / pipefail weirdness
  "$SECRETS_REFRESH_BIN" >&2 2>&1 || true
else
  # Fallback: devbox wrapper
  devbox global run secrets-refresh >&2 2>&1 || true
fi
CACHE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/devbox-secrets.sh"
if [ -f "$CACHE" ] && grep -q "^export $ENV_VAR=" "$CACHE"; then
  echo "${GREEN}✓${NC} \$$ENV_VAR populated in $CACHE" >&2
else
  echo "${YELLOW}⚠${NC} \$$ENV_VAR NOT in cache yet — you still need to register it in secrets-refresh:" >&2
  echo "    ${CYAN}[\"$ITEM_NAME\"]=\"$ENV_VAR\"${NC}" >&2
fi
