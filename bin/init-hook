#!/usr/bin/env bash
# init-hook — sourced by devbox shell init_hook
# Must be sourced (not executed) so `return` and exports persist.

# Non-interactive short-circuit
[ "${-#*i}" == "$-" ] || [ ! -t 0 ] || [ -z "$PS1" ] || [ -n "$TOOLBOX_PATH" ] && return

# Source Bitwarden secrets cache (fast, regenerable)
XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" && [ -n "$XDG_RUNTIME_DIR" ] && [ -f "$XDG_RUNTIME_DIR/devbox-secrets.sh" ] && . "$XDG_RUNTIME_DIR/devbox-secrets.sh"

# ble.sh line editor (if terminal input is not working, remove ~/.cache/blesh/)
[ -f $(blesh-share)/ble.sh ] && source -- $(blesh-share)/ble.sh --attach=none

# nix-ld must be enabled on the nix host
# "programs.nix-ld.enable = true;"
uname -v | grep -q 'NixOS' && export NIX_LD=$(nix eval --impure --raw --expr '
let
  pkgs = import <nixpkgs> {};
  NIX_LD = pkgs.lib.fileContents "${pkgs.stdenv.cc}/nix-support/dynamic-linker";
in NIX_LD
')

# Starship prompt
command -v starship >/dev/null 2>&1 && eval "$(starship init bash --print-full-init)"

# zoxide (aliases cd to z)
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init bash)" && alias cd='z'

# fzf keybindings
command -v fzf >/dev/null 2>&1 && source <(fzf --bash)

export SUDO_EDITOR=$DEVBOX_PACKAGES_DIR/bin/nvim
set -o vi

# atuin history
command -v atuin >/dev/null 2>&1 && eval "$(atuin init --disable-up-arrow bash)"

# bash completions
for f in "$DEVBOX_PACKAGES_DIR/share/bash-completion/completions/"*; do
  [ $(basename $f) = Makemodule.am ] || [ $(basename $f) = enosys ] && continue
  source "$f"
done

# Python virtual environment setup
[ -d "$VENV_DIR" ] || python3 -m venv "$VENV_DIR"
[ -f "$VENV_DIR/bin/activate" ] && . "$VENV_DIR/bin/activate"

# Make nix flakes' Python packages importable via `python -m`
nix_py="$DEVBOX_PROJECT_ROOT/.devbox/nix/profile/default/lib/python3.12/site-packages"
[ -d "$nix_py" ] && printf '%s\n' "$nix_py" > "$VENV_DIR/lib/python3.12/site-packages/nix-profiles.pth"

# ble.sh attach
[[ ! ${BLE_VERSION-} ]] || ble-attach
