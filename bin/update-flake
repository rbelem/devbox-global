#!/usr/bin/env bash
# devbox-global-update-flake
# Lists devbox global packages, identifies flake packages,
# checks latest GitHub version, and optionally updates them.
set -euo pipefail

# ── Argument parsing ──
# Positional args = packages to update (no -u flag needed, since
# devbox intercepts dash flags before passing to scripts).
# Use -u/--update for direct script invocation (bypassing devbox).
SHOW_HELP=false
ALL_FLAKES=false
declare -a UPDATE_TARGETS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u|--update)
            shift
            while [[ $# -gt 0 && ! "$1" == -* ]]; do
                UPDATE_TARGETS+=("$1")
                shift
            done
            ;;
        -a|--all)
            ALL_FLAKES=true
            shift
            ;;
        -h|--help)
            SHOW_HELP=true
            shift
            ;;
        -*)
            echo "Unknown flag: $1"
            exit 1
            ;;
        *)
            # Positional arg = package to update
            UPDATE_TARGETS+=("$1")
            shift
            ;;
    esac
done

if $SHOW_HELP; then
    echo "Usage: $(basename "$0") [PKG...]"
    echo "Check and optionally update devbox global flake packages."
    echo ""
    echo "  PKG [...]    Update specific packages by name"
    echo "  -a, --all    Update all packages with available updates"
    echo "  (no args)    Show version comparison table"
    echo "  -u PKG [...] Alternative to positional args (for direct use)"
    echo "  -h, --help   Show this help"
    exit 0
fi

DEVBOX_GLOBAL_PATH="$(devbox global path)"
DEVBOX_JSON="$DEVBOX_GLOBAL_PATH/devbox.json"
DEVBOX_D="$DEVBOX_GLOBAL_PATH/devbox.d"

# Colors (declared before preflight so error paths can use them under set -u)
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# ── Preflight: gh must be installed and authenticated ──
# gh release list / gh api calls below use `2>/dev/null || true` to keep
# detection robust, but a missing gh auth causes ALL packages to show "unknown"
# silently. Fail fast with a clear message instead.
if ! command -v gh >/dev/null 2>&1; then
    echo "${RED}ERROR${NC}: gh is not installed." >&2
    echo "Install: ${BOLD}nix-env -iA nixpkgs.gh${NC} or your distro's package manager." >&2
    exit 1
fi
if ! gh auth status >/dev/null 2>&1; then
    echo "${RED}ERROR${NC}: gh is not authenticated." >&2
    echo "Run: ${BOLD}gh auth login${NC}" >&2
    exit 1
fi

# Fake hash placeholder — literal string, works in any nix scope (no pkgs dependency)
FAKE_HASH='sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA='

# ── Parse installed versions from `devbox global list` ──
declare -A INSTALLED
while IFS= read -r line; do
    line="${line#\* }"
    if [[ "$line" == path:* ]]; then
        name="${line#path:}"
        name="${name#devbox.d/}"
        INSTALLED["$name"]="flake"
    else
        pkg="${line%% -*}"
        ver="${line##* - }"
        ver="${ver## }"
        name="${pkg%@*}"
        INSTALLED["$name"]="$ver"
    fi
done < <(devbox global list 2>/dev/null)

# ── Extract flake package names from devbox.json (JSONC-safe) ──
declare -a FLAKES=()
while IFS= read -r entry; do
    if [[ "$entry" == path:* ]]; then
        name="${entry#path:}"
        name="${name#devbox.d/}"
        FLAKES+=("$name")
    fi
done < <(grep -oP '"path:devbox\.d/[^"]+"|"[^"]+@latest"' "$DEVBOX_JSON" | tr -d '"' | grep '^path:')

# ── For each flake, extract GitHub source + version from flake.nix ──
declare -A FLAKE_OWNER FLAKE_REPO FLAKE_VERSION FLAKE_TYPE \
         FLAKE_UPSTREAM FLAKE_FORK_SUFFIX FLAKE_RELEASE_PREFIX

for name in "${FLAKES[@]}"; do
    flake_nix="$DEVBOX_D/$name/flake.nix"
    [[ -f "$flake_nix" ]] || continue

    # Extract version from explicit version attribute
    ver="$(grep -oP '\bversion\s*=\s*"\K[^"]+' "$flake_nix" | head -1 || true)"

    # Fallback: extract version from flake input URL refs (e.g. github:owner/repo/v1.2.3)
    if [[ -z "$ver" ]]; then
        ver="$(grep -oP '"github:[^/"]+/[^/"]+/\K[^"]+' "$flake_nix" | grep -vE '^(nixos-unstable|main|master|develop|nightly)$' | head -1 || true)"
        ver="${ver#v}"
    fi

    FLAKE_VERSION["$name"]="$ver"

    found_source=false

    # Strategy 1: fetchFromGitHub with owner/repo attrs (most specific, no false positives)
    owner="$(grep -oP 'owner\s*=\s*"\K[^"]+' "$flake_nix" | grep -v NixOS | head -1 || true)"
    repo="$(grep -oP 'repo\s*=\s*"\K[^"]+' "$flake_nix" | grep -v nixpkgs | head -1 || true)"
    if [[ -n "$owner" && -n "$repo" ]]; then
        FLAKE_OWNER["$name"]="$owner"
        FLAKE_REPO["$name"]="$repo"
        FLAKE_TYPE["$name"]="fetchFromGitHub"
        found_source=true
    fi

    # Strategy 2: github:owner/repo input URLs (non-nixpkgs)
    if ! $found_source; then
        input_url="$(grep -oP '"github:[^"]+' "$flake_nix" | grep -v 'github:NixOS/nixpkgs' | head -1 || true)"
        if [[ -n "$input_url" ]]; then
            input_url="${input_url#\"}"
            input_url="${input_url#github:}"
            owner="${input_url%%/*}"
            rest="${input_url#*/}"
            repo="${rest%%/*}"
            FLAKE_OWNER["$name"]="$owner"
            FLAKE_REPO["$name"]="$repo"
            FLAKE_TYPE["$name"]="github-input"
            found_source=true
        fi
    fi

    # Strategy 3: homepage attribute (meta.homepage or homepage) points to source repo
    # Useful when source is fetched from elsewhere (npm, GitHub releases) but
    # the code repo is on GitHub. Avoids false positives from embedded dependency URLs.
    if ! $found_source; then
        homepage_url="$(grep -oP 'homepage\s*=\s*"https://github\.com/\K[^/"]+/[^/"]+' "$flake_nix" | head -1 || true)"
        if [[ -n "$homepage_url" ]]; then
            owner="${homepage_url%/*}"
            repo="${homepage_url#*/}"
            FLAKE_OWNER["$name"]="$owner"
            FLAKE_REPO["$name"]="$repo"
            FLAKE_TYPE["$name"]="homepage"
            found_source=true
        fi
    fi

    # Strategy 4: fetchurl/fetchzip with github.com/owner/repo URL (least specific, most false positives)
    if ! $found_source; then
        url="$(grep -oP 'github\.com/[^/"]+/[^/"]+' "$flake_nix" | grep -v 'NixOS/nixpkgs' | head -1 || true)"
        if [[ -n "$url" ]]; then
            owner="$(echo "$url" | cut -d'/' -f2)"
            repo="$(echo "$url" | cut -d'/' -f3)"
            repo="${repo%.git}"
            FLAKE_OWNER["$name"]="$owner"
            FLAKE_REPO["$name"]="$repo"
            FLAKE_TYPE["$name"]="fetchurl"
            found_source=true
        fi
    fi

    # Extract fork metadata from flake.nix comments:
    #   # upstream: owner/repo       → check this repo for new releases
    #   # fork-suffix: -perl         → appended to upstream version for fork version
    #   # release-prefix: cli-v      → filter tags by this prefix (e.g. cli-v, skill-v)
    upstream_comment="$(grep -oP '^[[:space:]]*#\s*upstream:\s*\K\S+' "$flake_nix" 2>/dev/null || true)"
    fork_suffix_comment="$(grep -oP '^[[:space:]]*#\s*fork-suffix:\s*\K\S+' "$flake_nix" 2>/dev/null || true)"
    release_prefix_comment="$(grep -oP '^[[:space:]]*#\s*release-prefix:\s*\K\S+' "$flake_nix" 2>/dev/null || true)"
    [[ -n "$upstream_comment" ]] && FLAKE_UPSTREAM["$name"]="$upstream_comment"
    [[ -n "$fork_suffix_comment" ]] && FLAKE_FORK_SUFFIX["$name"]="$fork_suffix_comment"
    [[ -n "$release_prefix_comment" ]] && FLAKE_RELEASE_PREFIX["$name"]="$release_prefix_comment"
done

# ── Check latest GitHub version ──
declare -A LATEST

for name in "${FLAKES[@]}"; do
    owner="${FLAKE_OWNER[$name]:-}"
    repo="${FLAKE_REPO[$name]:-}"

    if [[ -z "$owner" || -z "$repo" ]]; then
        LATEST["$name"]="unknown"
        continue
    fi

    # For forked flakes, check upstream repo for latest version
    if [[ -n "${FLAKE_UPSTREAM[$name]:-}" ]]; then
        owner="${FLAKE_UPSTREAM[$name]%/*}"
        repo="${FLAKE_UPSTREAM[$name]#*/}"
    fi

    release_prefix="${FLAKE_RELEASE_PREFIX[$name]:-}"

    # Try GitHub releases first (exclude pre-releases).
    # NOTE: `2>/dev/null || true` is intentional — API errors (rate limit,
    # 404 for private repos, etc.) fall through to "unknown" for that
    # package rather than aborting the whole run. The preflight gh-auth
    # check above ensures at least the AUTH case is loud.
    latest_tags="$(gh release list -R "$owner/$repo" --limit 20 -L 20 --json tagName,isPrerelease -q '.[] | select(.isPrerelease == false) | .tagName' 2>/dev/null || true)"

    if [[ -n "$latest_tags" ]]; then
        if [[ -n "$release_prefix" ]]; then
            # Custom release prefix (e.g. cli-v, skill-v) — filter by it
            latest_tag="$(echo "$latest_tags" | grep "^${release_prefix}" | head -1 || true)"
            # If no match, don't fallthrough — this repo has no matching releases
            [[ -z "$latest_tag" ]] && latest_tags=""
        else
            # Prefer tags starting with "v" (standard semver: vX.Y.Z).
            latest_tag="$(echo "$latest_tags" | grep '^v' | head -1 || true)"
            # If no v-prefixed release, try known platform prefixes (bun-v, mac-v)
            # that are still version tags (e.g. bun-v1.3.14, mac-v1.2.3).
            if [[ -z "$latest_tag" ]]; then
                latest_tag="$(echo "$latest_tags" | grep -E '^(bun-v|mac-v)' | head -1 || true)"
            fi
            # If none match a known version prefix, releases are likely CI/action
            # tags (e.g. github-action-v1.0.2) — fall through to git tags.
            if [[ -z "$latest_tag" ]]; then
                latest_tags=""
            fi
        fi
    fi

    if [[ -n "$latest_tags" ]]; then
        if [[ -n "$release_prefix" ]]; then
            # Strip release prefix (e.g. cli-v3.1.0 → 3.1.0)
            latest_ver="${latest_tag#$release_prefix}"
            latest_ver="${latest_ver#v}"
        else
            # Strip common prefixes: v, bun-v, mac-v
            latest_ver="${latest_tag#v}"
            latest_ver="${latest_ver#bun-v}"
            latest_ver="${latest_ver#mac-v}"
        fi
        LATEST["$name"]="$latest_ver"
    else
        # Fall back to tags — same v-prefix preference
        all_tags="$(gh api "repos/$owner/$repo/tags" --jq '.[].name' 2>/dev/null || true)"
        if [[ -n "$all_tags" ]]; then
            if [[ -n "$release_prefix" ]]; then
                latest_tag="$(echo "$all_tags" | grep "^${release_prefix}" | head -1 || true)"
            else
                latest_tag="$(echo "$all_tags" | grep '^v' | head -1 || true)"
            fi
            if [[ -z "$latest_tag" ]]; then
                latest_tag="$(echo "$all_tags" | head -1)"
            fi
            if [[ -n "$release_prefix" ]]; then
                latest_ver="${latest_tag#$release_prefix}"
                latest_ver="${latest_ver#v}"
            else
                latest_ver="${latest_tag#v}"
                latest_ver="${latest_ver#bun-v}"
                latest_ver="${latest_ver#mac-v}"
            fi
            LATEST["$name"]="$latest_ver"
        else
            # Fall back to default branch
            latest_branch="$(gh api "repos/$owner/$repo" --jq '.default_branch' 2>/dev/null || true)"
            if [[ -n "$latest_branch" ]]; then
                LATEST["$name"]="branch:$latest_branch"
            else
                LATEST["$name"]="unknown"
            fi
        fi
    fi
done

# ── Update a single flake package ──
update_flake() {
    local name="$1" old_ver="$2" new_ver="$3"
    local flake_nix="$DEVBOX_D/$name/flake.nix"
    local owner="${FLAKE_OWNER[$name]:-}"
    local repo="${FLAKE_REPO[$name]:-}"

    [[ -f "$flake_nix" ]] || { echo "  File not found"; return 1; }
    [[ -z "$old_ver" || "$old_ver" == "flake" ]] && { echo "  Cannot determine installed version"; return 1; }

    # For forked flakes, append fork suffix to the new version
    local update_ver="$new_ver"
    if [[ -n "${FLAKE_FORK_SUFFIX[$name]:-}" ]]; then
        update_ver="${new_ver}${FLAKE_FORK_SUFFIX[$name]}"
    fi

    [[ "$old_ver" == "$update_ver" ]] && { echo "  Already at latest: $old_ver"; return 0; }

    echo "  ${BOLD}${name}${NC}: $old_ver → $update_ver  (${owner}/${repo})"

    # Escape dots for sed
    old_ver_escaped="${old_ver//\./\\.}"

    # 1. Update version field
    if grep -qP "\\bversion\\s*=\\s*\"$old_ver_escaped\"" "$flake_nix"; then
        sed -ri "s/(\\bversion\\s*=\\s*)\"$old_ver_escaped\"/\\1\"$update_ver\"/" "$flake_nix"
        echo "    ✓ version field updated"
    else
        echo "    ! Could not find version = \"$old_ver\" in flake.nix — skipping"
        return 1
    fi

    # 2. Update input URL refs for github-input type flakes (e.g. github:owner/repo/v1.2.3)
    if [[ "${FLAKE_TYPE[$name]:-}" == "github-input" ]]; then
        sed -ri "s|(/v)$old_ver_escaped\"|\1$update_ver\"|g; s|(/)${old_ver_escaped}\"|\1${update_ver}\"|g" "$flake_nix"
        echo "    ✓ input URL ref updated"
    fi

    # 3. Reset hashes to a literal fake hash (no pkgs dependency, works in any scope)
    #    Named attrs: hash, srcHash, cargoHash, npmDepsHash, npmDistHash,
    #                 nodeModulesHash, outputHash
    #    Quoted attrs: "platform" = "sha256-..." (agent-browser pattern)
    #    Uses ERE (sed -r), no PCRE non-capturing groups.
    if grep -qE '(^|[[:space:]])(hash|srcHash|cargoHash|npmDepsHash|npmDistHash|nodeModulesHash|outputHash)[[:space:]]*=[[:space:]]*"sha256-' "$flake_nix" 2>/dev/null \
        || grep -qE '"[^"]+"[[:space:]]*=[[:space:]]*"sha256-' "$flake_nix" 2>/dev/null; then
        sed -ri 's/((^|[[:space:]])(hash|srcHash|cargoHash|npmDepsHash|npmDistHash|nodeModulesHash|outputHash)[[:space:]]*=[[:space:]]*)"(sha256-[^"]+)"/\1"'"$FAKE_HASH"'";  # FIXME: was "\4"/' "$flake_nix"
        sed -ri 's/("[^"]+"[[:space:]]*=[[:space:]]*)"(sha256-[^"]+)"/\1"'"$FAKE_HASH"'";  # FIXME: was "\2"/' "$flake_nix"
        echo "    ✓ hashes reset to fakeHash"
    else
        echo "    - no hashes to reset"
    fi
}

# ── Auto-resolve hashes by building and capturing "got" hash ──
resolve_hashes() {
    local name="$1"
    local flake_dir="$DEVBOX_D/$name"
    local flake_nix="$flake_dir/flake.nix"
    local max_attempts=10
    local result=1  # default: failure
    local attempt=0

    # Only if hashes were reset to fakeHash
    if grep -qF "$FAKE_HASH" "$flake_nix" 2>/dev/null; then
        echo ""
        echo "    Computing hashes (building with nix)..."

        for ((attempt=1; attempt<=max_attempts; attempt++)); do
            # Check if all fakeHash placeholders are resolved
            if ! grep -qF "$FAKE_HASH" "$flake_nix" 2>/dev/null; then
                echo "    ${GREEN}✓${NC} all hashes resolved"
                result=0
                break
            fi

            # Build the flake and capture output.
            # `timeout 600` guards against stalled substituters / wedged networks —
            # max_attempts bounds FAILED attempts but a hung build blocks forever otherwise.
            local build_output
            if build_output=$(cd "$flake_dir" && timeout 600 nix build --no-link ".#default" 2>&1); then
                echo "    ${GREEN}✓${NC} build succeeded"
                result=0
                break
            fi

            # Extract "got" hash from error output.
            # NOTE: avoid `grep -oP '...\K...'` (PCRE lookbehind) — Alpine/musl/busybox
            # greps don't support -P. Use ERE with sed to strip the prefix.
            local got_hash
            got_hash=$(echo "$build_output" | grep -oE 'got:[[:space:]]+sha256-[a-zA-Z0-9+/=]+' | head -1 | sed -E 's/^got:[[:space:]]+//')

            if [[ -z "$got_hash" ]]; then
                echo "    ${YELLOW}!${NC} non-hash build error:"
                echo "$build_output" | grep -E '(error:|Error:)' | head -5 | sed 's/^/      /'
                break
            fi

            # Replace only the first occurrence (only the hash the current build
            # is failing on). sed address range `0,/PATTERN/` stops at the first
            # line containing PATTERN, so multi-hash flakes progress one hash
            # per build iteration. The trailing `; # FIXME: was "..."` audit
            # comment (injected by the reset step above) is stripped from the
            # same line — it's only meaningful during the resolution loop.
            sed -i -e "0,/${FAKE_HASH//\//\\/}/{s/${FAKE_HASH//\//\\/}/${got_hash//\//\\/}/}" "$flake_nix"
            sed -i -E -e "0,/${got_hash//\//\\/}/{s/;[[:space:]]*#[[:space:]]*FIXME:[[:space:]]*was[[:space:]]*\"sha256-[^\"]*\"//}" "$flake_nix"
            echo "    hash $attempt: $got_hash"
        done
    else
        result=0
    fi

    # Final cleanup: strip any FIXME residue left behind (e.g. from previous
    # bumps where one arch's hash could not be resolved on the host arch).
    # Idempotent — no-op on clean files.
    sed -i -E 's/;[[:space:]]*#[[:space:]]*FIXME:[[:space:]]*was[[:space:]]*"[^"]*"//g' "$flake_nix" 2>/dev/null || true

    if [[ $result -eq 1 && $attempt -ge $max_attempts ]]; then
        echo "    ${YELLOW}!${NC} max retries reached"
    fi

    return $result
}

# ── Print results ──
printf "\n${BOLD}${CYAN}═══ Devbox Global Flake Packages ═══${NC}\n\n"
printf "${BOLD}%-15s %-25s %-15s %-15s %-8s${NC}\n" "PACKAGE" "SOURCE" "INSTALLED" "LATEST" "STATUS"
printf "%-15s %-25s %-15s %-15s %-8s\n" "───────" "──────" "─────────" "──────" "──────"

for name in "${FLAKES[@]}"; do
    installed="${FLAKE_VERSION[$name]:-${INSTALLED[$name]:-unknown}}"
    latest="${LATEST[$name]:-unknown}"
    type="${FLAKE_TYPE[$name]:-unknown}"
    owner="${FLAKE_OWNER[$name]:-}"
    repo="${FLAKE_REPO[$name]:-}"

    source_display="$owner/$repo"
    [[ -z "$owner" ]] && source_display="$type"

    # For forked flakes, strip fork suffix before comparing with latest
    compare_installed="$installed"
    if [[ -n "${FLAKE_FORK_SUFFIX[$name]:-}" ]]; then
        compare_installed="${installed%${FLAKE_FORK_SUFFIX[$name]}}"
    fi

    # Determine status
    if [[ "$latest" == "unknown" || "$installed" == "unknown" || "$latest" == branch:* ]]; then
        status="${YELLOW}??${NC}"
    elif [[ "$compare_installed" == "$latest" ]]; then
        status="${GREEN}✓${NC}"
    else
        status="${RED}↑${NC}"
    fi

    latest_display="${latest#branch:}"

    printf "%-15s %-25s %-15s %-15s %b\n" "$name" "$source_display" "$installed" "$latest_display" "$status"
done

printf "\n${BOLD}${CYAN}═══ Nixpkgs Packages ═══${NC}\n\n"
printf "${BOLD}%-20s %-15s %-8s${NC}\n" "PACKAGE" "INSTALLED" "SOURCE"
printf "%-20s %-15s %-8s\n" "───────" "─────────" "──────"

for name in "${!INSTALLED[@]}"; do
    ver="${INSTALLED[$name]}"
    [[ "$ver" == "flake" ]] && continue
    is_flake=false
    for fname in "${FLAKES[@]}"; do
        [[ "$name" == "$fname" ]] && { is_flake=true; break; }
    done
    $is_flake && continue
    printf "%-20s %-15s %s\n" "$name" "$ver" "nixpkgs"
done | sort

printf "\n"
printf "${GREEN}✓${NC} = up to date  ${RED}↑${NC} = update available  ${YELLOW}??${NC} = unknown\n"

# ── Update workflow ──
if [[ ${#UPDATE_TARGETS[@]} -gt 0 || $ALL_FLAKES == true ]]; then
    # Build list of upgradable packages
    declare -a UPGRADABLE=()
    for name in "${FLAKES[@]}"; do
        installed="${FLAKE_VERSION[$name]:-${INSTALLED[$name]:-unknown}}"
        latest="${LATEST[$name]:-unknown}"

        # For forked flakes, strip fork suffix before comparing with latest
        compare_installed="$installed"
        if [[ -n "${FLAKE_FORK_SUFFIX[$name]:-}" ]]; then
            compare_installed="${installed%${FLAKE_FORK_SUFFIX[$name]}}"
        fi

        if [[ "$installed" != "unknown" && "$latest" != "unknown" && "$latest" != branch:* && "$compare_installed" != "$latest" ]]; then
            UPGRADABLE+=("$name")
        fi
    done

    # Tell the user explicitly when --all / -u finds nothing — silent no-op is confusing.
    if [[ ${#UPGRADABLE[@]} -eq 0 ]]; then
        if $ALL_FLAKES; then
            echo ""
            echo "${GREEN}${BOLD}All flake packages are already at latest.${NC}"
        elif [[ ${#UPDATE_TARGETS[@]} -gt 0 ]]; then
            echo ""
            echo "${GREEN}${BOLD}No updates available for the requested packages.${NC}"
        fi
    fi

    # Validate targets against known flakes
    declare -a TARGETS=()
    if $ALL_FLAKES; then
        TARGETS=("${UPGRADABLE[@]}")
    fi
    if [[ ${#UPDATE_TARGETS[@]} -gt 0 ]]; then
        for target in "${UPDATE_TARGETS[@]}"; do
            found=false
            for name in "${UPGRADABLE[@]}"; do
                [[ "$name" == "$target" ]] && { found=true; break; }
            done
            if $found; then
                TARGETS+=("$target")
            else
                # Check if it's a known flake
                is_flake=false
                for name in "${FLAKES[@]}"; do
                    [[ "$name" == "$target" ]] && { is_flake=true; break; }
                done
                if ! $is_flake; then
                    echo "  Package '$target' is not a known flake package."
                elif grep -qF "$FAKE_HASH" "$DEVBOX_D/$target/flake.nix" 2>/dev/null; then
                    # Version matches but hashes not fully resolved — retry resolution
                    TARGETS+=("$target")
                else
                    installed="${FLAKE_VERSION[$target]:-${INSTALLED[$target]:-unknown}}"
                    echo "  Package '$target' is already at $installed (no update needed)."
                fi
            fi
        done
    fi

    if [[ ${#TARGETS[@]} -gt 0 ]]; then
        echo ""
        echo "${BOLD}${CYAN}Applying updates...${NC}"
        for name in "${TARGETS[@]}"; do
            echo ""
            installed="${FLAKE_VERSION[$name]:-${INSTALLED[$name]:-unknown}}"
            latest="${LATEST[$name]:-unknown}"
            update_flake "$name" "$installed" "$latest" || true
            resolve_hashes "$name" || echo "    ${YELLOW}!${NC} hash resolution incomplete (see above)"
        done
        echo ""
        echo "${BOLD}${GREEN}All updates applied.${NC}"
        echo ""
        echo "→ Running post-install hooks..."
        "$DEVBOX_GLOBAL_PATH/bin/post-install"
    fi
fi

printf "\n"
