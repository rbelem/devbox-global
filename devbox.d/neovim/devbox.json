{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "path:.",
    "luarocks@latest",
    "tree-sitter@latest"
  ],
  "env": {
    "SUDO_EDITOR": "$DEVBOX_PACKAGES_DIR/bin/nvim"
  },
  "shell": {
    "scripts": {
      "setup-neovim": [
        "git clone https://github.com/rbelem/nvchad-custom $HOME/.config/nvim"
      ]
    }
  }
}