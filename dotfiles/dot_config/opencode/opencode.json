{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax/MiniMax-M3",
  "small_model": "opencode-go/mimo-v2.5",
  "provider": {
    "omniroute": {
      "name": "OmniRoute (omniroute-provider)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "omniroute-local"
      },
      "models": {
        "glm-5.2": {
          "name": "GLM-5.2 (omniroute auto-routed)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "opencode-zen/glm-5.2": {
          "name": "GLM-5.2 (Zen overflow)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "opencode-zen/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (Zen)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 384000
          }
        },
        "opencode-zen/deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free (Zen)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 384000
          }
        },
        "openrouter/z-ai/glm-5.2": {
          "name": "GLM-5.2 (OpenRouter overflow)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1048576,
            "output": 131072
          }
        },
        "opencode-go/minimax-m3": {
          "name": "MiniMax-M3 (Go, MiniMax Max plan)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "opencode-go/kimi-k2.7-code": {
          "name": "Kimi K2.7 Code (Go, fast code model)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 131072
          }
        },
        "zai/glm-5.2": {
          "name": "GLM-5.2 (z.ai Coding Pro subscription, 2-3x quota multiplier)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "zai/glm-4.7": {
          "name": "GLM-4.7 (z.ai Coding Pro subscription, 1x quota - preferred for routine)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 131072
          }
        },
        "opencode-go/mimo-v2.5": {
          "name": "Mimo v2.5 (Go free tier, fast subagent work)",
          "reasoning": false,
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "moonshotai/kimi-k3": {
          "name": "Kimi K3 (Moonshot direct, 2.8T multimodal reasoning, 1M ctx)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "moonshotai/kimi-k2.7-code": {
          "name": "Kimi K2.7 Code (Moonshot direct, coding specialist)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 131072
          }
        },
        "moonshotai/kimi-k2.7-code-highspeed": {
          "name": "Kimi K2.7 Code Highspeed (Moonshot direct, speed-optimized coding)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 131072
          }
        },
        "opencode-go/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (Go free tier, fast cheap)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "opencode-go/mimo-v2.5-pro": {
          "name": "Mimo v2.5 Pro (Go free tier, value fixer)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "opencode-go/qwen3.7-max": {
          "name": "Qwen 3.7 Max (Go free tier, reasoning specialist)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 16384
          }
        }
      }
    },
    "moonshotai": {
      "models": {
        "kimi-k3": {
          "temperature": false
        }
      }
    }
  },
  "experimental": {
    "disable_paste_summary": true,
    "mcp_timeout": 30000
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "cors": []
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true
    },
    "browsermcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@browsermcp/mcp@latest"
      ],
      "enabled": false
    },
    "Framelink MCP for Figma": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key={env:FIGMA_API_KEY}",
        "--stdio"
      ],
      "enabled": false
    },
    "tmux": {
      "type": "local",
      "command": [
        "uvx",
        "libtmux-mcp"
      ],
      "environment": {
        "LIBTMUX_SAFETY": "read+send"
      }
    },
    "brave-search": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": false
    },
    "opencode-docs": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "opencode-docs-mcp@latest"
      ],
      "enabled": true
    },
    "agentmemory": {
      "type": "local",
      "command": [
        "agentmemory",
        "mcp"
      ],
      "enabled": true
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "timeout": 600000,
      "enabled": true
    },
    "openrouter": {
      "type": "remote",
      "url": "https://mcp.openrouter.ai/mcp",
      "enabled": false
    },
    "firecrawl-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "firecrawl-mcp"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      },
      "enabled": true
    },
    "omniroute": {
      "type": "local",
      "command": [
        "omniroute",
        "--mcp"
      ],
      "environment": {
        "PRICING_SYNC_ENABLED": "true",
        "PRICING_SYNC_INTERVAL": "86400",
        "PRICING_SYNC_SOURCES": "litellm"
      },
      "enabled": true
    },
    "docling": {
      "type": "local",
      "command": [
        "docling-mcp-server",
        "--transport",
        "stdio"
      ],
      "enabled": false
    }
  },
  "tools": {
    "omniroute_gamification_*": false,
    "omniroute_plugin_*": false,
    "omniroute_omniroute_oneproxy_*": false,
    "omniroute_omniroute_pool_*": false,
    "omniroute_omniroute_browser_pool_*": false,
    "omniroute_omniroute_github_skills_*": false,
    "omniroute_omniroute_skills_*": false,
    "omniroute_omniroute_agent_skills_*": false,
    "firecrawl-mcp_firecrawl_monitor_*": false,
    "firecrawl-mcp_firecrawl_research_*": false,
    "firecrawl-mcp_firecrawl_agent*": false,
    "chrome-devtools_performance_*": false,
    "chrome-devtools_lighthouse_*": false,
    "chrome-devtools_take_heapsnapshot": false,
    "docling_*": false
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.agents/*": "allow",
      "~/.config/opencode/skills/*": "allow",
      "~/.local/share/devbox/global/default": "allow",
      "~/Workspace/rbelem/*": "allow",
      "~/Workspace/github.com/rbelem/*": "allow",
      "/tmp/*": "allow"
    },
    "lsp": "allow",
    "question": "allow",
    "skill": {
      "*": "allow"
    },
    "todowrite": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "doom_loop": "deny"
  },
  "plugin": [
    "@slkiser/opencode-quota",
    "@ramarivera/opencode-model-announcer",
    "@tarquinen/opencode-smart-title",
    "./plugins/agentmemory-capture.ts",
    "./plugins/autolearn.js",
    "./plugins/dcg-guard.ts",
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "autolearn-reviewer": {
      "description": "Reviews past conversations for self-improvement opportunities",
      "hidden": true,
      "steps": 20,
      "prompt": "Load the autolearn-reviewer skill and follow its instructions to review the attached conversation for learning opportunities. Take immediate action: record observations, update memory, create or patch skills.",
      "permission": {
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "write": "allow",
        "edit": "deny",
        "webfetch": "deny",
        "task": "deny",
        "skill": "allow",
        "external_directory": "allow"
      }
    }
  },
  "compaction": {
    "tail_turns": 10
  },
  "tool_output": {
    "max_lines": 400
  },
  "formatter": true,
  "lsp": true,
  "instructions": [
    "/home/rodrigo/.autolearn/personas/default/memory.context.md"
  ]
}
