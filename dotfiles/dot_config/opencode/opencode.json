{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/glm-5.2",
  "small_model": "opencode-go/kimi-k2.6",
  "provider": {
    "omniroute": {
      "name": "OmniRoute",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "omniroute-local"
      },
      "models": {
        "opencode-zen/gpt-5.5": {
          "name": "GPT-5.5 (Zen)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1050000, "output": 128000 }
        },
        "opencode-zen/gpt-5.5-pro": {
          "name": "GPT-5.5 Pro (Zen)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1050000, "output": 128000 }
        },
        "opencode-zen/gpt-5.4": {
          "name": "GPT-5.4 (Zen)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 409600, "output": 131072 }
        },
        "opencode-zen/gpt-5.4-pro": {
          "name": "GPT-5.4 Pro (Zen)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 409600, "output": 131072 }
        },
        "opencode-zen/claude-opus-4-7": {
          "name": "Claude Opus 4.7 (Zen)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 128000 }
        },
        "opencode-zen/claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Zen)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 64000 }
        },
        "opencode-zen/gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Zen)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1048576, "output": 65535 }
        },
        "opencode-zen/grok-4.5": {
          "name": "Grok 4.5 (Zen)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 200000, "output": 8192 }
        },
        "opencode-zen/glm-5.2": {
          "name": "GLM-5.2 (Zen overflow)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 131072 }
        },
        "opencode-zen/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (Zen)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 384000 }
        },
        "opencode-zen/deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free (Zen)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 384000 }
        },
        "openrouter/z-ai/glm-5.2": {
          "name": "GLM-5.2 (OpenRouter overflow)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1048576, "output": 131072 }
        },
        "openrouter/anthropic/claude-opus-4.8": {
          "name": "Claude Opus 4.8 (OpenRouter)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 128000 }
        },
        "openrouter/openai/gpt-5.5-pro": {
          "name": "GPT-5.5 Pro (OpenRouter)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1050000, "output": 128000 }
        },
        "openrouter/google/gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro (OpenRouter)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1048576, "output": 65536 }
        },
        "openrouter/deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (OpenRouter)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1048576, "output": 384000 }
        }
      }
    }
  },
  "experimental": {
    "disable_paste_summary": true,
    "mcp_timeout": 30000
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "cors": []
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": false
    },
    "browsermcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@browsermcp/mcp@latest"
      ],
      "enabled": false
    },
    "Framelink MCP for Figma": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key={env:FIGMA_API_KEY}",
        "--stdio"
      ],
      "enabled": false
    },
    "tmux": {
      "type": "local",
      "command": ["uvx", "libtmux-mcp"],
      "environment": {
        "LIBTMUX_SAFETY": "read+send"
      }
    },
    "brave-search": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": false
    },
    "opencode-docs": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "opencode-docs-mcp@latest"
      ],
      "enabled": true
    },
    "agentmemory": {
      "type": "local",
      "command": ["agentmemory", "mcp"],
      "enabled": true
    },
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "timeout": 600000,
      "enabled": true
    },
    "openrouter": {
      "type": "remote",
      "url": "https://mcp.openrouter.ai/mcp",
      "enabled": true
    },
    "firecrawl-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "firecrawl-mcp"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      }
    },
    "omniroute": {
      "type": "local",
      "command": ["omniroute", "--mcp"],
      "enabled": true
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.agents/*": "allow",
      "~/.config/opencode/get-shit-done/*": "allow",
      "~/.config/opencode/skills/*": "allow",
      "~/.local/share/devbox/global/default": "allow",
      "~/Workspace/github.com/rbelem/*": "allow",
      "/tmp/*": "allow"
    },
    "lsp": "allow",
    "question": "allow",
    "skill": {
      "*": "allow"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "doom_loop": "deny"
  },
  "plugin": [
    "@slkiser/opencode-quota",
    "@ramarivera/opencode-model-announcer",
    "@tarquinen/opencode-smart-title",
    "oh-my-opencode-slim",
    "./plugins/agentmemory-capture.ts"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "compaction": {
    "tail_turns": 15
  },
  "tool_output": {
    "max_lines": 500
  },
  "formatter": true,
  "lsp": true
}
