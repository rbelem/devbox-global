{
  "$schema": "https://opencode.ai/config.json",
  "model": "omniroute/openrouter/z-ai/glm-5.2",
  "small_model": "opencode-go/kimi-k2.6",
  "provider": {
    "omniroute": {
      "name": "OmniRoute",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "omniroute-local"
      },
      "models": {
        "opencode-zen/glm-5.2": {
          "name": "GLM-5.2 (Zen overflow)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 131072 }
        },
        "opencode-zen/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (Zen)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 384000 }
        },
        "opencode-zen/deepseek-v4-flash-free": {
          "name": "DeepSeek V4 Flash Free (Zen)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 384000 }
        },
        "openrouter/z-ai/glm-5.2": {
          "name": "GLM-5.2 (OpenRouter overflow)",
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1048576, "output": 131072 }
        }
      }
    }
  },
  "experimental": {
    "disable_paste_summary": true,
    "mcp_timeout": 30000
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "cors": []
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true
    },
    "browsermcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@browsermcp/mcp@latest"
      ],
      "enabled": true
    },
    "Framelink MCP for Figma": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key={env:FIGMA_API_KEY}",
        "--stdio"
      ],
      "enabled": false
    },
    "tmux": {
      "type": "local",
      "command": [
        "uvx",
        "libtmux-mcp"
      ],
      "environment": {
        "LIBTMUX_SAFETY": "read+send"
      }
    },
    "brave-search": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": false
    },
    "opencode-docs": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "opencode-docs-mcp@latest"
      ],
      "enabled": true
    },
    "agentmemory": {
      "type": "local",
      "command": [
        "agentmemory",
        "mcp"
      ],
      "enabled": true
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "timeout": 600000,
      "enabled": true
    },
    "openrouter": {
      "type": "remote",
      "url": "https://mcp.openrouter.ai/mcp",
      "enabled": true
    },
    "firecrawl-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "firecrawl-mcp"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      }
    },
    "omniroute": {
      "type": "local",
      "command": [
        "omniroute",
        "--mcp"
      ],
      "enabled": true
    },
    "docling": {
      "type": "local",
      "command": ["docling-mcp-server", "--transport", "stdio"],
      "enabled": true
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.agents/*": "allow",
      "~/.config/opencode/skills/*": "allow",
      "~/.local/share/devbox/global/default": "allow",
      "~/Workspace/rbelem/*": "allow",
      "~/Workspace/github.com/rbelem/*": "allow",
      "/tmp/*": "allow"
    },
    "lsp": "allow",
    "question": "allow",
    "skill": {
      "*": "allow"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "doom_loop": "deny"
  },
  "plugin": [
    "@slkiser/opencode-quota",
    "@ramarivera/opencode-model-announcer",
    "@tarquinen/opencode-smart-title",
    "oh-my-opencode-slim",
    "./plugins/agentmemory-capture.ts",
    "./plugins/autolearn.js"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "autolearn-reviewer": {
      "description": "Reviews past conversations for self-improvement opportunities",
      "hidden": true,
      "steps": 20,
      "prompt": "Load the autolearn-reviewer skill and follow its instructions to review the attached conversation for learning opportunities. Take immediate action: record observations, update memory, create or patch skills.",
      "permission": {
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "write": "allow",
        "edit": "deny",
        "webfetch": "deny",
        "task": "deny",
        "skill": "allow",
        "external_directory": "allow"
      }
    }
  },
  "compaction": {
    "tail_turns": 10
  },
  "tool_output": {
    "max_lines": 400
  },
  "formatter": true,
  "lsp": true,
  "instructions": [
    "/home/rodrigo/.autolearn/personas/default/memory.context.md"
  ]
}
