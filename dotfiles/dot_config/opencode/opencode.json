{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "experimental": {
    "background_subagents": true,
    "disable_paste_summary": true
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": false
    },
    "browsermcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@browsermcp/mcp@latest"
      ],
      "enabled": false
    },
    "Framelink MCP for Figma": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key={env:FIGMA_API_KEY}",
        "--stdio"
      ],
      "enabled": false
    },
    "tmux": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "tmux-mcp"
      ]
    },
    "brave-search": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
      },
      "enabled": false
    },
    "opencode-docs": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "opencode-docs-mcp@latest"
      ],
      "enabled": false
    },
    "agentmemory": {
      "type": "local",
      "command": ["agentmemory", "mcp"],
      "enabled": true
    }
  },
  "permission": {
    "external_directory": {
      "*": "ask",
      "~/.agents/*": "allow",
      "~/.config/opencode/skills/*": "allow",
      "/tmp/*": "allow",
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "lsp": "allow",
    "question": "allow",
    "skill": {
      "*": "allow",
      "caveman": "allow",
      "caveman-commit": "allow",
      "find-skill": "allow"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "doom_loop": "deny"
  },
  "plugin": [
    "@slkiser/opencode-quota",
    "@ramarivera/opencode-model-announcer",
    "@tarquinen/opencode-smart-title",
    "oh-my-opencode-slim@2.0.0-beta.13",
    "./plugins/agentmemory-capture.ts"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}
